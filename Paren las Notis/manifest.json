{
  "manifest_version": 3,
  "name": "Paren las Notis — Notificaciones de Paren la Mano",
  "version": "1.0.0",
  "description": "Recibí notificaciones cada vez que resuben los programas de Paren la Mano en Vorterix.",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}